# Bangumi API 配置
BANGUMI_BASE_URL=https://api.bgm.tv/v0
BANGUMI_USER_AGENT=bangumi_list/1.0.0 (+https://github.com/yourusername/bangumi_list)

# 请求配置
REQUEST_TIMEOUT=30
REQUEST_RETRY_TIMES=3
REQUEST_RETRY_DELAY=1.0
REQUEST_INTERVAL=0.5

# 缓存配置
CACHE_ENABLED=true
CACHE_DIR=cache
CACHE_TTL=3600

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=logs
